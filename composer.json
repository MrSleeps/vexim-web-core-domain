{
    "name": "mrsleeps/vexim-web-core-domain",
    "description": "Domain management for VExim Web UI",
    "type": "filament-plugin",
    "license": "GPL-3.0-only",
    "authors": [
        {
            "name": "Mr Sleeps"
        }
    ],
    "require": {
        "php": "^8.4",
        "filament/filament": "^5.0",
        "illuminate/support": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "VEximweb\\Core\\Domain\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "VEximweb\\Core\\Domain\\DomainServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "1.x-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
